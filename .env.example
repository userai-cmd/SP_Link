# PostgreSQL connection string (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sp_link

# Set to "true" when the database requires SSL (Railway external connections)
PGSSL=false

# Secret for signing JWT tokens — REQUIRED in production
JWT_SECRET=change-me-to-a-long-random-string

# Bootstrap admin account (created on first start)
ADMIN_EMAIL=admin@sat.ua
ADMIN_PASSWORD=admin12345

# HTTP port (Railway provides PORT automatically)
PORT=3000

# Directory for uploaded files
UPLOAD_DIR=uploads
